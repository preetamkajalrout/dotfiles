[user]
	name = Preetam Kajal Rout
	email = 3712035+preetamkajalrout@users.noreply.github.com
[core]
	editor = nvim
	autocrlf = input
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	theme = OneHalfDark
[color]
	ui = auto
[log]
	decorate = auto
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
