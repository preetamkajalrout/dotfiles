[core]
	editor = nvim
	autocrlf = input
[color]
	ui = auto
[log]
	decorate = auto
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
